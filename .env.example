# FreeCurrencyAPI key - get one at https://freecurrencyapi.com/
FREECURRENCY_API_KEY=your_api_key_here

# NextAuth
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub Personal Access Token for issue reporting
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=your_github_token_here

# GitHub repository for issues (default: pascalwhoop/universalNetCalc)
GITHUB_REPO=pascalwhoop/universalNetCalc
